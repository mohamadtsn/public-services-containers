#!/bin/bash
# bin/pubservices — Public Services Containers CLI

set -e

CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
BASE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

cd "$BASE_DIR"

VERSION_FILE="${BASE_DIR}/VERSION"
VERSION="$(tr -d '[:space:]' < "$VERSION_FILE" 2>/dev/null || echo "unknown")"

COMPOSE_PROFILES=(--profile proxy --profile pma --profile mail --profile storage)

usage() {
    echo ""
    echo -e "  ${CYAN}${BOLD}pubservices${RESET} ${DIM}v${VERSION}${RESET}  —  Public Services Containers CLI"
    echo ""
    echo -e "  ${BOLD}Usage:${RESET}"
    echo -e "    pubservices <command> [service]"
    echo ""
    echo -e "  ${BOLD}Commands:${RESET}"
    echo -e "    ${GREEN}status${RESET}            Show status of all services (health + ports)"
    echo -e "    ${GREEN}info${RESET}              Show connection info for all services"
    echo -e "    ${GREEN}up${RESET} [service]      Start all services (or one specific service)"
    echo -e "    ${GREEN}down${RESET}              Stop all services"
    echo -e "    ${GREEN}restart${RESET} [service] Restart services (or one specific service)"
    echo -e "    ${GREEN}reload-proxy${RESET}      Reload Nginx configuration (nginx -s reload)"
    echo -e "    ${GREEN}logs${RESET} [service]    Follow service logs (or one specific service)"
    echo -e "    ${GREEN}edit${RESET}              Edit .env in \$EDITOR"
    echo -e "    ${GREEN}update${RESET}                     Check for updates and install if available"
    echo -e "    ${GREEN}backup${RESET}                     Backup MySQL and Redis data"
    echo -e "    ${GREEN}restore${RESET} <file>             Restore from a backup archive"
    echo -e "    ${GREEN}build${RESET}                      Rebuild Docker images (no cache)"
    echo -e "    ${GREEN}run${RESET} <cmd...>               Run any command inside the installation directory"
    echo -e "    ${GREEN}static-add${RESET} <name> [src]    Sync a build directory into nginx/static/ (uses rsync)"
    echo -e "    ${GREEN}static-remove${RESET} <name>       Remove a static site from nginx/static/"
    echo -e "    ${GREEN}static-list${RESET}                List static sites in nginx/static/"
    echo -e "    ${GREEN}static-mount${RESET} [path]        Create override file to mount path into nginx (Option B)"
    echo -e "    ${GREEN}static-unmount${RESET}             Remove the override file"
    echo -e "    ${GREEN}reset${RESET}                      Stop all services and delete data (DESTRUCTIVE)"
    echo -e "    ${GREEN}help${RESET}                       Show this help message"
    echo ""
    echo -e "  ${BOLD}Examples:${RESET}"
    echo -e "    pubservices up"
    echo -e "    pubservices logs mysql"
    echo -e "    pubservices restart redis"
    echo -e "    pubservices reload-proxy"
    echo -e "    pubservices edit"
    echo ""
}

# ─── Helpers ───────────────────────────────────────────────────────────────────

# Print a status table row with ANSI-aware column alignment
_row() {
    local name="$1" stat="$2" port="$3"
    local bare pad
    bare="$(printf '%s' "$stat" | sed $'s/\033\\[[0-9;]*m//g')"
    pad=$(( 20 - ${#bare} ))
    printf "  ${CYAN}│${RESET}  %-12s  %s%*s  %-24s ${CYAN}│${RESET}\n" \
        "$name" "$stat" "$pad" "" "$port"
}

container_status() {
    local name="$1"
    local status
    status=$(docker inspect --format='{{.State.Status}}' "$name" 2>/dev/null) || status=""
    status="${status//[$'\t\r\n ']/}"
    [[ -z "$status" ]] && status="not found"
    local health
    health=$(docker inspect --format='{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}' "$name" 2>/dev/null) || health=""
    health="${health//[$'\t\r\n ']/}"

    if [[ "$status" == "running" ]]; then
        if [[ "$health" == "healthy" ]]; then
            echo -e "${GREEN}● running${RESET}"
        elif [[ "$health" == "unhealthy" ]]; then
            echo -e "${RED}● unhealthy${RESET}"
        elif [[ "$health" == "starting" ]]; then
            echo -e "${YELLOW}● starting${RESET}"
        else
            echo -e "${GREEN}● running${RESET}"
        fi
    elif [[ "$status" == "not found" ]]; then
        echo -e "${DIM}○ not found${RESET}"
    elif [[ "$status" == "exited" || "$status" == "created" ]]; then
        echo -e "${YELLOW}○ stopped${RESET}"
    else
        echo -e "${RED}○ ${status}${RESET}"
    fi
}

load_env() {
    if [[ -f "${BASE_DIR}/.env" ]]; then
        # shellcheck disable=SC1091
        set -a; source "${BASE_DIR}/.env"; set +a
    fi
}

# ─── Commands ──────────────────────────────────────────────────────────────────

cmd_status() {
    load_env

    local mysql_name="${MYSQL_CONTAINER_NAME:-mysql-main}"
    local redis_name="${REDIS_CONTAINER_NAME:-redis-main}"
    local nginx_name="${NGINX_CONTAINER_NAME:-nginx-main}"
    local pma_name="${PMA_CONTAINER_NAME:-phpmyadmin}"
    local mailpit_name="${MAILPIT_CONTAINER_NAME:-mailpit}"
    local minio_name="${MINIO_CONTAINER_NAME:-minio}"

    local mysql_port="${MYSQL_PORT:-43306}"
    local redis_port="${REDIS_PORT:-46379}"
    local http_port="${NGINX_HTTP_PORT:-80}"
    local https_port="${NGINX_HTTPS_PORT:-443}"
    local pma_port="${PMA_PORT:-18080}"
    local mailpit_http="${MAILPIT_HTTP_PORT:-8025}"
    local minio_console="${MINIO_CONSOLE_PORT:-9001}"
    local minio_api="${MINIO_API_PORT:-9000}"

    local mysql_st redis_st nginx_st pma_st mailpit_st minio_st
    mysql_st=$(container_status "$mysql_name")
    redis_st=$(container_status "$redis_name")
    nginx_st=$(container_status "$nginx_name")
    pma_st=$(container_status "$pma_name")
    mailpit_st=$(container_status "$mailpit_name")
    minio_st=$(container_status "$minio_name")

    echo ""
    echo -e "  ${CYAN}╭─ Public Services ─────────────────────────────────────────────╮${RESET}"
    _row "MySQL"      "$mysql_st"   "localhost:${mysql_port}"
    _row "Redis"      "$redis_st"   "localhost:${redis_port}"
    _row "Nginx"      "$nginx_st"   ":${http_port} / :${https_port}"
    _row "phpMyAdmin" "$pma_st"     "http://localhost:${pma_port}"
    _row "Mailpit"    "$mailpit_st" "http://localhost:${mailpit_http}"
    _row "MinIO"      "$minio_st"   ":${minio_console} (API :${minio_api})"
    echo -e "  ${CYAN}╰───────────────────────────────────────────────────────────────╯${RESET}"
    echo ""
}

cmd_info() {
    load_env

    local mysql_port="${MYSQL_PORT:-43306}"
    local redis_port="${REDIS_PORT:-46379}"
    local pma_port="${PMA_PORT:-18080}"
    local mailpit_http="${MAILPIT_HTTP_PORT:-8025}"
    local mailpit_smtp="${MAILPIT_SMTP_PORT:-1025}"
    local minio_console="${MINIO_CONSOLE_PORT:-9001}"
    local minio_api="${MINIO_API_PORT:-9000}"

    echo ""
    echo -e "  ${CYAN}${BOLD}Connection Info${RESET}"
    echo ""
    echo -e "  ${BOLD}MySQL${RESET}"
    echo -e "    Host     : localhost"
    echo -e "    Port     : ${mysql_port}"
    echo -e "    Database : ${MYSQL_DATABASE:-main}"
    echo -e "    User     : ${MYSQL_USER:-main_user}"
    echo -e "    Password : ${MYSQL_PASSWORD:-password}"
    echo ""
    echo -e "  ${BOLD}Redis${RESET}"
    echo -e "    Host     : localhost"
    echo -e "    Port     : ${redis_port}"
    echo ""
    echo -e "  ${BOLD}phpMyAdmin${RESET}"
    echo -e "    URL      : http://localhost:${pma_port}"
    echo ""
    echo -e "  ${BOLD}Mailpit${RESET}"
    echo -e "    UI       : http://localhost:${mailpit_http}"
    echo -e "    SMTP     : localhost:${mailpit_smtp}"
    echo ""
    echo -e "  ${BOLD}MinIO${RESET}"
    echo -e "    Console  : http://localhost:${minio_console}"
    echo -e "    API      : http://localhost:${minio_api}"
    echo -e "    User     : ${MINIO_ROOT_USER:-minioadmin}"
    echo -e "    Password : ${MINIO_ROOT_PASSWORD:-minioadmin}"
    echo ""
}

cmd_up() {
    local service="${1:-}"
    if [[ -n "$service" ]]; then
        docker compose up -d "$service"
    else
        docker compose "${COMPOSE_PROFILES[@]}" up -d
    fi
}

cmd_down() {
    docker compose "${COMPOSE_PROFILES[@]}" down
}

cmd_restart() {
    local service="${1:-}"
    if [[ -n "$service" ]]; then
        docker compose restart "$service"
    else
        docker compose "${COMPOSE_PROFILES[@]}" restart
    fi
}

cmd_reload() {
    load_env
    local nginx_name="${NGINX_CONTAINER_NAME:-nginx-main}"

    if ! docker inspect "$nginx_name" &>/dev/null; then
        echo -e "${RED}✗ Nginx container '${nginx_name}' is not running.${RESET}"
        exit 1
    fi

    echo -e "${CYAN}›${RESET} Testing Nginx configuration..."
    if docker exec "$nginx_name" nginx -t; then
        echo -e "${CYAN}›${RESET} Reloading Nginx..."
        docker exec "$nginx_name" nginx -s reload
        echo -e "${GREEN}✓ Nginx reloaded successfully.${RESET}"
    else
        echo -e "${RED}✗ Nginx configuration test failed — not reloading.${RESET}"
        exit 1
    fi
}

cmd_logs() {
    local service="${1:-}"
    if [[ -n "$service" ]]; then
        docker compose logs -f "$service"
    else
        docker compose "${COMPOSE_PROFILES[@]}" logs -f
    fi
}

cmd_edit() {
    local env_file="${BASE_DIR}/.env"
    if [[ ! -f "$env_file" ]]; then
        echo -e "${YELLOW}⚠  .env not found — copying from .env.example${RESET}"
        cp "${BASE_DIR}/.env.example" "$env_file"
    fi
    ${EDITOR:-${VISUAL:-nano}} "$env_file"
}

cmd_update() {
    local repo="mohamadtsn/public-services-containers"
    local current_clean="${VERSION#v}"

    echo -e "${CYAN}›${RESET} Checking for updates..."

    local latest_tag=""
    if command -v curl &>/dev/null; then
        latest_tag=$(curl -fsSL "https://api.github.com/repos/${repo}/releases/latest" \
            2>/dev/null | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')
    elif command -v wget &>/dev/null; then
        latest_tag=$(wget -qO- "https://api.github.com/repos/${repo}/releases/latest" \
            2>/dev/null | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')
    else
        echo -e "${RED}✗ curl or wget is required to check for updates.${RESET}"
        exit 1
    fi

    if [[ -z "$latest_tag" ]]; then
        echo -e "${RED}✗ Could not fetch latest version — check your internet connection.${RESET}"
        exit 1
    fi

    local latest_version="${latest_tag#v}"

    if [[ "$current_clean" == "$latest_version" ]]; then
        echo -e "${GREEN}✓ Already up to date (v${current_clean}).${RESET}"
        echo ""
        exit 0
    fi

    echo ""
    echo -e "  Installed : ${GREEN}v${current_clean}${RESET}"
    echo -e "  Available : ${CYAN}${latest_tag}${RESET}"
    echo ""
    read -r -p "  Update from v${current_clean} → ${latest_tag}? [Y/n]: " confirm </dev/tty
    confirm="${confirm:-y}"
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "\n  ${YELLOW}Update cancelled.${RESET}\n"
        exit 0
    fi
    echo ""

    local install_url="https://raw.githubusercontent.com/${repo}/master/scripts/install.sh"
    echo -e "${CYAN}›${RESET} Running update installer..."
    echo ""
    sudo bash -c "AUTO_CONFIRM=1 bash <(curl -fsSL '${install_url}')"
}

cmd_backup() {
    bash "${BASE_DIR}/scripts/backup.sh"
}

cmd_restore() {
    local file="${1:-}"

    if [[ -z "$file" ]]; then
        read -r -p "  Backup file path: " file </dev/tty
    fi
    if [[ -z "$file" ]]; then
        echo -e "${RED}✗ File path is required.${RESET}"
        exit 1
    fi

    file="${file/#\~/$HOME}"

    if [[ ! -f "$file" ]]; then
        echo -e "${RED}✗ File not found: ${file}${RESET}"
        exit 1
    fi

    bash "${BASE_DIR}/scripts/restore.sh" "$file"
}

cmd_build() {
    local all_profiles=(--profile proxy --profile pma --profile mail --profile storage)
    echo -e "${CYAN}›${RESET} Rebuilding Docker images (no cache)..."
    docker compose "${all_profiles[@]}" build --no-cache
}

cmd_run() {
    if [[ $# -eq 0 ]]; then
        echo -e "${RED}✗ No command specified.${RESET}"
        echo -e "  ${DIM}Usage: pubservices run <command> [args...]${RESET}"
        echo -e "  ${DIM}Example: pubservices run make lint${RESET}"
        exit 1
    fi
    # BASE_DIR is already the working directory (set at top of script)
    "$@"
}

cmd_static_add() {
    local name="${1:-}"
    local src="${2:-}"

    if [[ -z "$name" ]]; then
        read -r -p "  Project name: " name </dev/tty
    fi
    if [[ -z "$name" ]]; then
        echo -e "${RED}✗ Name is required.${RESET}"
        exit 1
    fi

    if [[ -z "$src" ]]; then
        read -r -p "  Source directory: " src </dev/tty
    fi
    if [[ -z "$src" ]]; then
        echo -e "${RED}✗ Source directory is required.${RESET}"
        exit 1
    fi

    # Expand ~ manually since it may come from user input
    src="${src/#\~/$HOME}"

    if [[ ! -d "$src" ]]; then
        echo -e "${RED}✗ Source directory not found: ${src}${RESET}"
        exit 1
    fi

    local dest="${BASE_DIR}/nginx/static/${name}"
    mkdir -p "$dest"

    echo -e "${CYAN}›${RESET} Syncing into nginx/static/${name}..."

    if command -v rsync &>/dev/null; then
        rsync -a --delete --info=progress2 "${src%/}/" "${dest}/"
    else
        echo -e "${YELLOW}⚠  rsync not found — falling back to cp${RESET}"
        rm -rf "${dest:?}"
        mkdir -p "$dest"
        cp -r "${src%/}/." "$dest/"
    fi

    echo ""
    echo -e "  ${GREEN}✓ Synced to nginx/static/${name}${RESET}"
    echo -e "  ${DIM}Container path: /srv/static/${name}${RESET}"
    echo ""
    echo -e "  To register with devproxy (first time):"
    echo -e "  ${CYAN}devproxy create -h myapp.local --static --root /srv/static/${name}${RESET}"
    echo -e "  ${DIM}For subsequent syncs just run this command again — no devproxy step needed.${RESET}"
    echo ""
}

cmd_static_remove() {
    local name="${1:-}"

    if [[ -z "$name" ]]; then
        read -r -p "  Project name to remove: " name </dev/tty
    fi
    if [[ -z "$name" ]]; then
        echo -e "${RED}✗ Name is required.${RESET}"
        exit 1
    fi

    local dest="${BASE_DIR}/nginx/static/${name}"

    if [[ ! -d "$dest" ]]; then
        echo -e "${RED}✗ Static project not found: ${name}${RESET}"
        exit 1
    fi

    echo -e "${RED}${BOLD}Warning: This will delete nginx/static/${name}${RESET}"
    read -r -p "  Confirm? [y/N]: " confirm </dev/tty
    confirm="${confirm:-n}"
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "  ${YELLOW}Cancelled.${RESET}"
        exit 0
    fi

    rm -rf "${dest:?}"
    echo -e "${GREEN}✓ Removed nginx/static/${name}${RESET}"
    echo -e "${DIM}  Run 'devproxy remove -h DOMAIN' to clean up the nginx config too.${RESET}"
    echo ""
}

cmd_static_list() {
    local static_dir="${BASE_DIR}/nginx/static"

    echo ""
    echo -e "  ${CYAN}${BOLD}Static Sites${RESET}  ${DIM}(nginx/static/ → /srv/static/)${RESET}"
    echo ""

    local found=0
    for dir in "${static_dir}"/*/; do
        [[ -d "$dir" ]] || continue
        local name size files
        name=$(basename "$dir")
        size=$(du -sh "$dir" 2>/dev/null | cut -f1)
        files=$(find "$dir" -type f 2>/dev/null | wc -l | tr -d ' ')
        echo -e "  ${GREEN}●${RESET} ${BOLD}${name}${RESET}  ${DIM}${files} files, ${size}${RESET}"
        echo -e "    ${DIM}/srv/static/${name}${RESET}"
        found=1
    done

    if [[ "$found" -eq 0 ]]; then
        echo -e "  ${DIM}No static sites found.${RESET}"
        echo -e "  ${DIM}Use: pubservices static-add <name> <source-dir>${RESET}"
    fi
    echo ""
}

cmd_static_mount() {
    local override_file="${BASE_DIR}/docker-compose.override.yml"
    local mount_path="${1:-$HOME}"

    # Expand ~ manually since it may come from user input
    mount_path="${mount_path/#\~/$HOME}"

    if [[ ! -d "$mount_path" ]]; then
        echo -e "${RED}✗ Directory not found: ${mount_path}${RESET}"
        exit 1
    fi

    if [[ -f "$override_file" ]]; then
        echo -e "${YELLOW}⚠  docker-compose.override.yml already exists.${RESET}"
        echo -e "  ${DIM}${override_file}${RESET}"
        echo ""
        read -r -p "  Overwrite? [y/N]: " confirm </dev/tty
        confirm="${confirm:-n}"
        if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
            echo -e "  ${YELLOW}Cancelled.${RESET}"
            exit 0
        fi
    fi

    cat > "$override_file" <<EOF
# docker-compose.override.yml
# Generated by: pubservices static-mount
# Mounts ${mount_path} into nginx-main at the same path (read-only).
# This allows devproxy --static --root to use real host paths directly.
services:
  nginx:
    volumes:
      - "${mount_path}:${mount_path}:ro"
EOF

    echo ""
    echo -e "  ${GREEN}✓ Created docker-compose.override.yml${RESET}"
    echo -e "  ${DIM}Mounted: ${mount_path} → ${mount_path} (read-only)${RESET}"
    echo ""
    echo -e "  ${BOLD}Next steps:${RESET}"
    echo -e "  1. Restart nginx:  ${CYAN}pubservices run make up-proxy${RESET}"
    echo -e "  2. Register site:  ${CYAN}devproxy create -h myapp.local --static --root /path/to/dist${RESET}"
    echo ""
    echo -e "  ${DIM}To undo: pubservices static-unmount${RESET}"
    echo ""
}

cmd_static_unmount() {
    local override_file="${BASE_DIR}/docker-compose.override.yml"

    if [[ ! -f "$override_file" ]]; then
        echo -e "${YELLOW}⚠  docker-compose.override.yml not found — nothing to remove.${RESET}"
        exit 0
    fi

    echo -e "${YELLOW}⚠  This will delete docker-compose.override.yml and the home-dir mount.${RESET}"
    read -r -p "  Confirm? [y/N]: " confirm </dev/tty
    confirm="${confirm:-n}"
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo -e "  ${YELLOW}Cancelled.${RESET}"
        exit 0
    fi

    rm -f "$override_file"
    echo -e "${GREEN}✓ Removed docker-compose.override.yml${RESET}"
    echo -e "${DIM}  Run 'make up-proxy' to restart nginx without the mount.${RESET}"
    echo ""
}

cmd_reset() {
    echo -e "${RED}${BOLD}Warning: This will permanently delete all MySQL, Redis, and MinIO data!${RESET}"
    echo ""
    read -r -p "  Type 'yes' to confirm: " confirm
    if [[ "$confirm" != "yes" ]]; then
        echo -e "\n  ${YELLOW}Reset cancelled.${RESET}\n"
        exit 0
    fi
    docker compose "${COMPOSE_PROFILES[@]}" down -v
    rm -rf "${BASE_DIR}/data/mysql/"* "${BASE_DIR}/data/redis/"* "${BASE_DIR}/data/minio/"*
    echo -e "\n  ${GREEN}✓ All data removed.${RESET}\n"
}

# ─── Dispatch ──────────────────────────────────────────────────────────────────

COMMAND="${1:-help}"
shift || true

case "$COMMAND" in
    status)  cmd_status ;;
    info)    cmd_info ;;
    up)      cmd_up "$@" ;;
    down)    cmd_down ;;
    restart) cmd_restart "$@" ;;
    reload-proxy)  cmd_reload ;;
    logs)    cmd_logs "$@" ;;
    edit)    cmd_edit ;;
    update)   cmd_update ;;
    backup)   cmd_backup ;;
    restore)  cmd_restore "$@" ;;
    build)    cmd_build ;;
    run)      cmd_run "$@" ;;
    static-add)     cmd_static_add "$@" ;;
    static-remove)  cmd_static_remove "$@" ;;
    static-list)    cmd_static_list ;;
    static-mount)   cmd_static_mount "$@" ;;
    static-unmount) cmd_static_unmount ;;
    reset)   cmd_reset ;;
    help|--help|-h) usage ;;
    *)
        echo -e "${RED}Unknown command: ${COMMAND}${RESET}"
        usage
        exit 1
        ;;
esac