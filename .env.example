# MySQL
MYSQL_DATABASE=main
MYSQL_USER=main_user
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=root
MYSQL_ALLOW_EMPTY_PASSWORD=no
MYSQL_PORT=43306

# Redis
REDIS_PORT=46379

# phpMyAdmin
PMA_PORT=18080
PMA_BLOWFISH_SECRET=change-this-to-a-32-char-string!!

# Mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_HTTP_PORT=8025

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Container names
# ⚠️  If you use local-dev-proxy, set NGINX_CONTAINER_NAME in ~/.local-dev-proxy.conf too (DOCKER_CONTAINER_NAME)
MYSQL_CONTAINER_NAME=mysql-main
REDIS_CONTAINER_NAME=redis-main
NGINX_CONTAINER_NAME=nginx-main
PMA_CONTAINER_NAME=phpmyadmin
MAILPIT_CONTAINER_NAME=mailpit
MINIO_CONTAINER_NAME=minio

# Network name
# ⚠️  If you use local-dev-proxy, set the network name in ~/.local-dev-proxy.conf too
NETWORK_NAME=public-service-network
