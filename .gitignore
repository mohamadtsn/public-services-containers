# Local data volumes (do not commit)
data/mysql/*
data/redis/*
data/minio/*
!data/mysql/.gitkeep
!data/redis/.gitkeep
!data/minio/.gitkeep

# Environment variables
.env

# Local Docker Compose overrides (e.g. home-dir mount for static sites)
docker-compose.override.yml

# phpMyAdmin
phpmyadmin/custom-themes/**/*

# Static sites build output (keep directory, ignore content)
nginx/static/*
!nginx/static/.gitkeep

# SSL certificates (keep the directory, not the certs)
nginx/certificates/*.crt
nginx/certificates/*.key
nginx/certificates/*.pem
nginx/certificates/*.p12

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db
