# Local data volumes (do not commit)
data/mysql/*
data/redis/*
data/minio/*
!data/mysql/.gitkeep
!data/redis/.gitkeep
!data/minio/.gitkeep

# Environment variables
.env

# phpMyAdmin
phpmyadmin/custom-themes/**/*

# SSL certificates (keep the directory, not the certs)
nginx/certificates/*.crt
nginx/certificates/*.key
nginx/certificates/*.pem
nginx/certificates/*.p12

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db
